{
  "name": "razor-project",
  "version": "1.0.0",
  "description": "Node.js REST API with Express, Sequelize, and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test:db:setup": "cross-env NODE_ENV=test npm run db:push",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "dev": "nodemon server.js"
